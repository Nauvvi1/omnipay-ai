# Omniston WebSocket endpoint. Production by default.
NEXT_PUBLIC_OMNISTON_WS=wss://omni-ws.ston.fi

# Optional: hosted URL used in TON Connect manifest generation notes.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: use a real Mira Flow HTTP wrapper if you create one.
# The app works without these by using the local deterministic intent parser.
MIRA_FLOW_ENDPOINT=
MIRA_API_KEY=
